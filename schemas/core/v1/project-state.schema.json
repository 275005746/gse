{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gse.local/schemas/core/v1/project-state.schema.json",
  "title": "GSE Core Project State v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "stateRevision", "activeChangeId"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "stateRevision": { "type": "integer", "minimum": 0 },
    "activeChangeId": { "type": ["string", "null"] },
    "projectName": { "type": "string" },
    "mode": { "type": "string" },
    "canonicalGoalSource": { "type": ["string", "null"] },
    "canonicalPlan": { "type": ["string", "null"] },
    "phase": { "type": ["string", "null"] },
    "currentSummary": { "type": ["object", "string", "null"] },
    "currentSlice": { "type": ["object", "string", "null"] },
    "toolStatuses": { "type": ["object", "null"] },
    "lastEvidence": { "type": ["string", "null"] },
    "blockedGates": { "type": "array" },
    "nextChecks": { "type": "array" },
    "residualRisks": { "type": "array", "items": { "type": "string" } },
    "riskHistoryPath": { "const": ".gse/risk-history.jsonl" },
    "archivedRiskCount": { "type": "integer", "minimum": 0 },
    "sourceRevision": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
