{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gse.local/schemas/core/v1/continuation-packet.schema.json",
  "title": "GSE Host-Native Continuation Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocol", "packetId", "sourceState", "planUnit", "next", "decision", "host", "authority", "requirements", "process", "reinjection", "evidence"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocol": { "const": "gse-host-native-continuation" },
    "packetId": { "type": "string", "pattern": "^continue-[a-f0-9]{24}$" },
    "sourceState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "digest"],
      "properties": {
        "revision": { "type": ["integer", "null"], "minimum": 0 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "planUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topLevelPlanUnitId", "currentSliceId"],
      "properties": {
        "topLevelPlanUnitId": { "type": ["string", "null"] },
        "currentSliceId": { "type": ["string", "null"] }
      }
    },
    "next": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sliceId", "title", "action"],
      "properties": {
        "kind": { "enum": ["current-slice", "next-slice"] },
        "sliceId": { "type": ["string", "null"] },
        "title": { "type": "string", "maxLength": 240 },
        "action": { "type": "string", "maxLength": 480 }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stopOutcome", "reasonCode", "canAutoContinue", "requiresHostReinjection"],
      "properties": {
        "stopOutcome": { "enum": ["continue-now", "await-decision", "blocked", "rollover-required", "top-level-complete"] },
        "reasonCode": { "type": "string", "minLength": 1 },
        "canAutoContinue": { "type": "boolean" },
        "requiresHostReinjection": { "type": "boolean" }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["negotiatedMode", "lifecycleStatus", "requiredCapability"],
      "properties": {
        "negotiatedMode": { "enum": ["host-autonomous-continuation", "host-turn-controlled"] },
        "lifecycleStatus": { "type": "string", "minLength": 1 },
        "requiredCapability": { "enum": ["verified-or-runtime-declared-native-goal-lifecycle", "packet-reinjection"] }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "scope", "prohibited", "claimBoundary"],
      "properties": {
        "owner": { "const": "host-goal-and-turn-lifecycle" },
        "scope": { "const": "same-approved-top-level-plan-unit" },
        "prohibited": { "type": "array", "items": { "type": "string" }, "minItems": 4, "uniqueItems": true },
        "claimBoundary": { "type": "string", "minLength": 1 }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preflight", "admission", "context", "evidence", "acceptance"],
      "properties": {
        "preflight": { "type": "array", "items": { "type": "string" }, "maxItems": 5 },
        "admission": { "type": "array", "items": { "type": "string" }, "maxItems": 1 },
        "context": { "type": "array", "items": { "type": "string" }, "maxItems": 2 },
        "evidence": { "type": "array", "items": { "type": "string" }, "maxItems": 2 },
        "acceptance": { "type": "array", "items": { "type": "string", "maxLength": 160 }, "maxItems": 4 }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "planningGranularity", "checkpointCadence", "reportingCadence", "reasonCodes", "capabilityBasis", "downgradeSignals", "invariants"],
      "properties": {
        "mode": { "enum": ["guided", "bounded", "autonomous"] },
        "planningGranularity": { "enum": ["detailed", "bounded", "outcome-focused"] },
        "checkpointCadence": { "enum": ["each-step", "risk-boundary", "completion-boundary"] },
        "reportingCadence": { "enum": ["frequent", "milestone", "exception-and-completion"] },
        "reasonCodes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "capabilityBasis": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "downgradeSignals": { "type": "array", "items": { "enum": ["validationFailure", "stateDrift", "unauthorizedOperationAttempt", "falseCompletionClaim", "repeatedRework"] }, "uniqueItems": true },
        "invariants": {
          "type": "object",
          "additionalProperties": false,
          "required": ["permissions", "securityBoundaries", "evidenceThresholds", "externalAuthorization", "destructiveAuthorization", "acceptanceAuthority"],
          "properties": {
            "permissions": { "const": "unchanged" },
            "securityBoundaries": { "const": "unchanged" },
            "evidenceThresholds": { "const": "unchanged" },
            "externalAuthorization": { "const": "unchanged" },
            "destructiveAuthorization": { "const": "unchanged" },
            "acceptanceAuthority": { "const": "unchanged" }
          }
        }
      }
    },
    "reinjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "prompt", "maxChars"],
      "properties": {
        "required": { "type": "boolean" },
        "prompt": { "type": "string", "maxLength": 700 },
        "maxChars": { "const": 700 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "hostDispatchObserved", "expectedReceiptFields"],
      "properties": {
        "stage": { "enum": ["none", "recommended", "acknowledged", "dispatched", "completed"] },
        "hostDispatchObserved": { "type": "boolean" },
        "expectedReceiptFields": { "type": "array", "items": { "type": "string" }, "minItems": 7, "uniqueItems": true }
      }
    }
  }
}
